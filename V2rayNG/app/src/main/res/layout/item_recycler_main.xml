<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/server_card_bg"    <!-- ဒီမှာ သုံးပါ -->
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_margin="8dp">

    <TextView
        android:id="@+id/tv_server_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#00FF41"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:text=">_ SERVER_01" />

    <TextView
        android:id="@+id/tv_server_address"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#55FF55"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginTop="4dp"
        android:text="[192.168.1.1:443]" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#00FF41"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <TextView
            android:id="@+id/tv_server_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#00FF41"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:text="[ STATUS: ONLINE ]" />

        <Button
            android:id="@+id/btn_connect"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/glow_button"
            android:text="CONNECT"
            android:textColor="#00FF41"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textAllCaps="false" />
    </LinearLayout>

</LinearLayout>
